{
  // Covers the Node-executed build config (vite.config.ts uses `path` and
  // `__dirname`). Kept separate from tsconfig.app.json so Node globals/types are
  // scoped to config files and never leak into browser `src` code. Mirrors the
  // Vite react-ts template's tsconfig.node.json.
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023"],
    "types": ["node"],
    "skipLibCheck": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true
  },
  "include": ["vite.config.ts"]
}
