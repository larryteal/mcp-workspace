  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.17.0",
    "@cloudflare/workers-types": "^4.20260129.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.9",
    "wrangler": "^4.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
